{
  "name": "stock-sentiment-daily-ingest",
  "tasks": [
    {
      "task_key": "ingest_news",
      "notebook_task": {
        "notebook_path": "/Repos/timlok@gmail.com/stocksentiment/databricks/ingest_news",
        "source": "WORKSPACE"
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 0,
        "spark_conf": {
          "spark.databricks.cluster.profile": "singleNode",
          "spark.master": "local[*]"
        },
        "custom_tags": {
          "ResourceClass": "SingleNode"
        }
      },
      "timeout_seconds": 600,
      "max_retries": 1,
      "min_retry_interval_millis": 60000
    }
  ],
  "max_concurrent_runs": 1,
  "format": "MULTI_TASK"
}
